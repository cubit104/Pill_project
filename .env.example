NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000
# Google Search Console verification token (from Settings → Ownership verification → HTML tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────
# Supabase configuration
# Required for both public site (image URLs) and admin dashboard (auth + storage)
# ─────────────────────────────────────────────

# Your Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings → API → anon public) — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Settings → API → service_role) — SERVER-SIDE ONLY, never expose in browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Admin dashboard configuration
# ─────────────────────────────────────────────

# Email of the first superadmin to bootstrap.
# After running migrations, this user must sign in via magic link first,
# then run: INSERT INTO admin_users (id, email, role) SELECT id, email, 'superadmin' FROM auth.users WHERE email = '<this email>'
ADMIN_BOOTSTRAP_EMAIL=admin@yourcompany.com

# Cookie name used for the admin session (optional, defaults to pillseek_admin_session)
ADMIN_SESSION_COOKIE_NAME=pillseek_admin_session

# Supabase Storage bucket name for pill images (check your Supabase Storage dashboard)
STORAGE_BUCKET=images

# Optional: Vercel deploy webhook URL for the "Rebuild site" button in /admin/settings
# If not set, the button is shown as disabled
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/your-hook-id

# ─────────────────────────────────────────────
# Analytics & SEO monitoring (admin /analytics dashboard)
# ─────────────────────────────────────────────

# Google Analytics 4 — GA4 Property ID (e.g. "123456789")
# Found in: GA4 → Admin → Property → Property details
# GA4_PROPERTY_ID=

# Google service account credentials JSON (used for both GA4 and Search Console)
# Option A: paste the entire JSON as a single-line string
# Option B: provide an absolute file path to the JSON key file
# To create: GCP console → IAM & Admin → Service Accounts → Create → add key (JSON)
# Then grant the service account "Viewer" access in GA4 and Search Console.
# GA4_SERVICE_ACCOUNT_JSON=

# Google Search Console site URL (must match exactly what's verified in GSC, e.g. "https://pillseek.com/")
# SEARCH_CONSOLE_SITE_URL=

# Google PageSpeed Insights API key
# Get one at: https://developers.google.com/speed/docs/insights/v5/get-started
# PAGESPEED_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# PostHog — product analytics, funnels, session replays
# Public site keys are safe to expose (write-only project token).
# ─────────────────────────────────────────────────────────────────────────────

# Public site tracking (Next.js frontend — pre-filled with the PillSeek project)
NEXT_PUBLIC_POSTHOG_KEY=phc_Bsh2XTkDrpUftJrZqM9Cgwe3km9Wk7gLWzdvrCUVJRfF
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Admin dashboard queries — requires a Personal API Key (server-side only, never expose in browser)
# Create in PostHog: Personal Settings → Personal API Keys → Create → scopes: query:read, session_recording:read, project:read
# POSTHOG_PERSONAL_API_KEY=

# PostHog project & host (backend — defaults work for the PillSeek project)
POSTHOG_PROJECT_ID=396739
POSTHOG_HOST=https://us.i.posthog.com

